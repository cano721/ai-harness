{
  "name": "ddalkak",
  "version": "3.0.0-alpha.0",
  "description": "AI Agent Governance & Orchestration Platform — 딸깍하면 에이전트가 움직인다",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "db:generate": "pnpm --filter @ddalkak/db run generate",
    "db:migrate": "pnpm --filter @ddalkak/db run migrate",
    "test": "node scripts/test-hooks.mjs hooks && node scripts/test-hooks.mjs teams/backend/hooks && node scripts/test-hooks.mjs teams/frontend/hooks",
    "test:packages": "vitest run",
    "lint": "eslint scripts/*.mjs",
    "validate:yaml": "node scripts/validate-yaml.mjs",
    "shellcheck": "shellcheck hooks/*.sh && find teams -name '*.sh' -exec shellcheck {} +"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "yaml": "^2.6.0"
  },
  "files": [
    ".claude-plugin",
    "CLAUDE.md",
    "skills/",
    "scripts/",
    "hooks/",
    "teams/",
    "templates/",
    "custom-agents/",
    "omc-integration/",
    "global/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cano721/ai-harness.git"
  },
  "keywords": [
    "ddalkak",
    "ai",
    "agent",
    "orchestration",
    "governance",
    "claude",
    "codex",
    "cursor",
    "convention"
  ],
  "license": "MIT",
  "author": "cano721",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
