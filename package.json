{
  "name": "ai-harness",
  "version": "1.0.0",
  "description": "AI 에이전트 제어/검증 프레임워크 — 프로젝트 분석 기반 컨벤션 자동 생성, 보안 Hook",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node scripts/test-hooks.mjs hooks && node scripts/test-hooks.mjs teams/backend/hooks && node scripts/test-hooks.mjs teams/frontend/hooks && node scripts/test-hooks.mjs teams/qa/hooks && node scripts/test-hooks.mjs teams/devops/hooks",
    "lint": "eslint scripts/*.mjs",
    "validate:yaml": "node scripts/validate-yaml.mjs",
    "shellcheck": "shellcheck hooks/*.sh && find teams -name '*.sh' -exec shellcheck {} +"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^17.4.0"
  },
  "dependencies": {
    "yaml": "^2.6.0"
  },
  "files": [
    ".claude-plugin",
    "CLAUDE.md",
    "skills/",
    "scripts/",
    "hooks/",
    "teams/",
    "templates/",
    "custom-agents/",
    "omc-integration/",
    "global/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cano721/ai-harness.git"
  },
  "keywords": [
    "ai",
    "harness",
    "claude",
    "claude-code",
    "plugin",
    "security",
    "hooks",
    "convention"
  ],
  "license": "MIT",
  "author": "cano721"
}
