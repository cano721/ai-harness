{
  "runtime": "claude",
  "displayName": "Claude Code",
  "homeDirName": ".claude",
  "contextSource": "AGENTS.md",
  "contextTarget": "CLAUDE.md",
  "skillsTargetDir": "skills",
  "agentsTargetDir": "agents",
  "templatesTargetDir": "planner-templates",
  "replacements": [
    {
      "from": "~/.codex/config.toml",
      "to": "~/.claude/settings.json"
    },
    {
      "from": ".codex/config.toml",
      "to": ".claude/settings.json"
    },
{
      "from": "~/.codex",
      "to": "{{TARGET_ROOT_TILDE}}"
    },
    {
      "from": "$HOME/.codex",
      "to": "$HOME/.claude"
    },
{
      "from": "$CODEX_HOME",
      "to": "$CLAUDE_HOME"
    },
    {
      "from": "CODEX_HOME",
      "to": "CLAUDE_HOME"
    },
    {
      "from": "Restart Codex",
      "to": "Restart Claude Code"
    },
    {
      "from": "restart Codex",
      "to": "restart Claude Code"
    },
    {
      "from": "Ask Codex",
      "to": "Ask Claude Code"
    },
    {
      "from": "launches Codex",
      "to": "launches Claude Code"
    },
    {
      "from": "launching Codex",
      "to": "launching Claude Code"
    },
    {
      "from": "start a new Codex session",
      "to": "start a new Claude Code session"
    },
    {
      "from": "start Codex with",
      "to": "start Claude Code with"
    },
    {
      "from": "Exiting Codex",
      "to": "Exiting Claude Code"
    },
    {
      "from": "exit Codex",
      "to": "exit Claude Code"
    },
    {
      "from": "# AGENTS.md",
      "to": "# CLAUDE.md"
    }
  ]
}
